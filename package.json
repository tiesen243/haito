{
  "name": "haito",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "format": "oxfmt --check ./apps ./packages",
    "format:fix": "oxfmt ./apps ./packages",
    "lint": "oxlint ./apps ./packages",
    "lint:fix": "oxlint --fix ./apps ./packages",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "turbo": "^2.10.2"
  },
  "overrides": {
    "@sinclair/typebox": "0.34.41"
  },
  "packageManager": "bun@1.3.0",
  "catalogs": {
    "dev": {
      "typescript": "^6.0.3",
      "tsdown": "^0.22.3"
    },
    "prod": {
      "@tanstack/react-query": "^5.101.2",
      "next-themes": "^0.4.6",
      "zod": "^4.4.3"
    },
    "react": {
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "react-dom": "^19.2.7",
      "react-native": "^0.86.0",
      "react": "^19.2.7"
    },
    "tailwind": {
      "@tailwindcss/vite": "^4.3.2",
      "tailwindcss": "^4.3.2",
      "uniwind": "^1.10.0"
    }
  }
}
