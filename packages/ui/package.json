{
  "name": "@haito/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/utils.d.mts",
      "default": "./dist/utils.mjs"
    },
    "./*": {
      "react-native": {
        "types": "./dist/components/native/*.d.mts",
        "default": "./dist/components/native/*.mjs"
      },
      "types": "./dist/components/*.d.mts",
      "default": "./dist/components/*.mjs"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.mts",
      "default": "./dist/hooks/*.mjs"
    },
    "./tailwind.css": "./dist/tailwind.css"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@haito/lib": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "lucide-react-native": "^1.23.0",
    "marked": "^18.0.5",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@haito/oxlint": "workspace:*",
    "@haito/tsconfig": "workspace:*",
    "@types/react": "catalog:react",
    "tailwindcss": "catalog:tailwind",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "peerDependencies": {
    "react": "catalog:react",
    "react-native": "catalog:react"
  }
}
