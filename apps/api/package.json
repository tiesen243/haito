{
  "name": "@haito/api",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/main.mjs",
  "types": "dist/main.d.mts",
  "exports": {
    ".": {
      "types": "./dist/main.d.mts",
      "default": "./dist/main.mjs"
    },
    "./dtos/*": {
      "types": "./dist/application/dtos/*.dto.d.mts",
      "default": "./dist/application/dtos/*.dto.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "db:generate": "drizzle-kit generate --config ./src/infrastructure/persistence/drizzle/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./src/infrastructure/persistence/drizzle/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ./src/infrastructure/persistence/drizzle/drizzle.config.ts",
    "dev": "bun run --hot src/main.ts",
    "start": "bun run dist/main.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/sql-pg": "^0.52.1",
    "@elysia/openapi": "^1.4.15",
    "@haito/lib": "workspace:*",
    "drizzle-orm": "^1.0.0-rc.4",
    "effect": "^3.21.4",
    "elysia": "^1.4.29",
    "pg": "^8.22.0",
    "zod": "catalog:prod"
  },
  "devDependencies": {
    "@haito/oxlint": "workspace:*",
    "@haito/tsconfig": "workspace:*",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^1.0.0-rc.4",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
